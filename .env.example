SHELFY_BOT_TOKEN=000000000:replace-me
SHELFY_DATABASE_URL=postgres://shelfy:shelfy@postgres:5432/shelfy?sslmode=disable
SHELFY_LOG_LEVEL=INFO
SHELFY_ENV=development
SHELFY_COPY_RUNTIME_PATH=copy/runtime.ru.yaml
SHELFY_DEFAULT_TIMEZONE=Europe/Moscow
SHELFY_DIGEST_LOCAL_TIME=09:00
SHELFY_POLL_TIMEOUT_SECONDS=30
SHELFY_JOB_POLL_INTERVAL=2s
SHELFY_SCHEDULER_INTERVAL=30s
SHELFY_TMP_DIR=/tmp/shelfy
SHELFY_OLLAMA_BASE_URL=http://host.docker.internal:11434
SHELFY_OLLAMA_MODEL=gemma3:4b
SHELFY_TESSERACT_COMMAND=tesseract
SHELFY_WHISPER_COMMAND=whisper-cli
SHELFY_WHISPER_MODEL_PATH=/models/ggml-base.bin
SHELFY_ENABLE_DEV_CONTROL_API=true
SHELFY_DEV_CONTROL_LISTEN_ADDR=:8081
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,postgres
