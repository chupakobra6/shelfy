# Core runtime
SHELFY_ENV=development
SHELFY_LOG_LEVEL=INFO
SHELFY_TMP_DIR=/tmp/shelfy
SHELFY_RUNTIME_BASE_IMAGE=shelfy-runtime-base:vosk-lib-0.3.45-small-ru-0.22

# Telegram and storage
SHELFY_BOT_TOKEN=000000000:replace-me
SHELFY_DATABASE_URL=postgres://shelfy:shelfy@postgres:5432/shelfy?sslmode=disable

# Copy and user defaults
SHELFY_COPY_RUNTIME_PATH=assets/copy/runtime.ru.yaml
SHELFY_DEFAULT_TIMEZONE=Europe/Moscow
SHELFY_DIGEST_LOCAL_TIME=09:00

# Polling and workers
SHELFY_POLL_TIMEOUT_SECONDS=30
SHELFY_JOB_POLL_INTERVAL=500ms
SHELFY_SCHEDULER_INTERVAL=30s

# LLM and ASR
SHELFY_OLLAMA_BASE_URL=http://host.docker.internal:11434
SHELFY_OLLAMA_MODEL=gemma3:4b
SHELFY_VOSK_COMMAND=/usr/local/bin/vosk-transcribe
SHELFY_VOSK_MODEL_PATH=/models/vosk-model-small-ru-0.22
SHELFY_VOSK_GRAMMAR_PATH=assets/asr/vosk-grammar.ru.json

# Dev control and deterministic E2E
# Keep enabled only in local development and test environments.
SHELFY_ENABLE_DEV_CONTROL_API=true
SHELFY_DEV_CONTROL_LISTEN_ADDR=:8081
SHELFY_E2E_TEST_USER_ID=123456789

# Optional outbound proxy
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,postgres
